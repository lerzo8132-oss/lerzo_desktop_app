{
  "appId": "com.lerzo.app",
  "productName": "Lerzo",
  "executableName": "Lerzo",
  "copyright": "Copyright © 2026 Lerzo",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "main.js",
    "preload.js",
    "package.json",
    "dist/**",
    "offline/**",
    "splash/**",
    "assets/**",
    "build/**",
    "config/loadApiConfig.js",
    "!.env"
  ],
  "extraResources": [
    {
      "from": "config",
      "to": "config",
      "filter": [
        "api-config*.json"
      ]
    }
  ],
  "win": {
    "target": ["nsis", "msi"],
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Lerzo"
  },
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "build/icon.icns",
    "category": "public.app-category.business",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "darkModeSupport": true
  },
  "dmg": {
    "title": "Lerzo Installer",
    "contents": [
      {
        "x": 410,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 130,
        "y": 150,
        "type": "file"
      }
    ]
  },
  "publish": {
    "provider": "github",
    "owner": "lerzo-org",
    "repo": "lerzo-desktop"
  }
}
