{
  "name": "lerzo",
  "version": "1.0.2",
  "productName": "Lerzo",
  "description": "Professional Management SaaS Desktop Application",
  "main": "main.js",
  "author": "Lerzo Team",
  "license": "MIT",
  "homepage": "https://app.lerzo.com",
  "keywords": [
    "Lerzo",
    "Desktop",
    "Electron",
    "SaaS",
    "Management"
  ],
  "scripts": {
    "start": "electron .",
    "vite:dev": "vite --host 127.0.0.1 --port 5173",
    "electron:dev": "LERZO_API_CONFIG_MODE=production wait-on http://127.0.0.1:5173 && LERZO_API_CONFIG_MODE=production electron .",
    "electron:dev:prod": "LERZO_API_CONFIG_MODE=production wait-on http://127.0.0.1:5173 && LERZO_API_CONFIG_MODE=production electron .",
    "dev": "npm run dev:prod",
    "dev:prod": "concurrently -k \"npm run vite:dev\" \"npm run electron:dev:prod\"",
    "vite:build": "vite build",
    "prepare:prod-config": "node scripts/prepare-production-config.mjs",
    "sanitize:prod-build": "node scripts/sanitize-production-build.mjs",
    "build": "npm run prepare:prod-config && npm run vite:build && npm run sanitize:prod-build && electron-builder",
    "build:prod": "npm run build",
    "build:win": "npm run prepare:prod-config && npm run vite:build && npm run sanitize:prod-build && electron-builder --win nsis msi --x64",
    "dist:win": "npm run build:win",
    "build:mac": "npm run vite:build && electron-builder --mac",
    "build:linux": "npm run vite:build && electron-builder --linux",
    "publish": "electron-builder --publish always",
    "clean": "rm -rf dist release node_modules",
    "clean:mac": "rm -rf ~/Library/Saved\\ Application\\ State/com.lerzo.desktop.savedState && rm -rf ~/Library/Caches/com.lerzo.desktop && killall Dock"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ajv": "^6.15.0",
    "autoprefixer": "^10.4.21",
    "axios": "^1.6.2",
    "concurrently": "^8.2.2",
    "dotenv": "^16.3.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-updater": "^6.1.7",
    "gsap": "^3.15.0",
    "lightningcss": "^1.32.0",
    "lucide-react": "^0.462.0",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "rolldown": "^1.1.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "uri-js": "^4.4.1",
    "vite": "^8.0.16",
    "wait-on": "^7.2.0"
  }
}
